# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL — format: postgresql://user:password@host:port/database
# For development: postgresql://postgres:postgres@localhost:5432/asata_dev
# For production: update with your cloud PostgreSQL credentials
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/asata_dev"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max donation requests per IP per 15 minutes
RATE_LIMIT_MAX=20
