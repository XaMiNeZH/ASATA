# ── Database ──────────────────────────────────────────────────────────────────
# SQLite — no server needed, just a local file
DATABASE_URL="file:./asata.db"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max donation requests per IP per 15 minutes
RATE_LIMIT_MAX=20
